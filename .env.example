# Copilot Telegram Bridge - Environment Configuration
# Copy this file to .env and fill in the values.

# === REQUIRED ===

# Telegram Bot token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (numeric). Send /start to @userinfobot to find it.
TELEGRAM_USER_ID=

# Your Telegram chat ID with the bot (often same as user ID for private chats).
# Send any message to the bot, then check https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# === OPTIONAL ===

# Path to the Copilot CLI executable (auto-detected if on PATH)
# COPILOT_PATH=C:\Users\behumphr\AppData\Local\Microsoft\WinGet\Packages\GitHub.Copilot_Microsoft.Winget.Source_8wekyb3d8bbwe\copilot.exe

# Working directory for the Copilot CLI session
# COPILOT_CWD=C:\Users\behumphr\source

# Milliseconds of quiet time before considering assistant response "done"
# OUTPUT_DEBOUNCE_MS=1500

# Terminal width (columns) for the PTY
# PTY_COLS=120

# Terminal height (rows) for the PTY
# PTY_ROWS=40
