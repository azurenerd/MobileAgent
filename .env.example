# Copilot Mobile Bridge - Environment Configuration
# Copy this file to .env and fill in the values.

# === TRANSPORT SELECTION ===
# Choose 'telegram' or 'teams' (default: telegram)
# TRANSPORT=telegram

# === TELEGRAM CONFIG (when TRANSPORT=telegram) ===

# Telegram Bot token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (numeric). Send /start to @userinfobot to find it.
TELEGRAM_USER_ID=

# Your Telegram chat ID with the bot (often same as user ID for private chats).
# Send any message to the bot, then check https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# === TEAMS CONFIG (when TRANSPORT=teams) ===

# Client ID for OAuth (default: Microsoft Graph PowerShell first-party app — works in all tenants)
# TEAMS_CLIENT_ID=14d82eec-204b-4c2f-b7e8-296a70dab67e

# Tenant ID (default: 'organizations' for multi-tenant)
# TEAMS_TENANT_ID=organizations

# UPN of the user to chat with. Options:
#   'me' (default) — uses your Teams "Message yourself" self-chat (simplest!)
#   'user@microsoft.com' — creates a 1:1 chat with another user
# TEAMS_RECIPIENT_UPN=me

# Existing Teams chat ID (skip chat creation/discovery)
# TEAMS_CHAT_ID=

# Poll interval in milliseconds (default: 3000)
# TEAMS_POLL_INTERVAL_MS=3000

# === COPILOT OPTIONS (both transports) ===

# Path to the Copilot CLI executable (auto-detected if on PATH)
# COPILOT_PATH=copilot

# Working directory for the Copilot CLI session
# COPILOT_CWD=C:\Users\you\source

# Timeout in seconds for each Copilot request (default: 90)
# COPILOT_TIMEOUT_SECONDS=90

# Model override (e.g., claude-sonnet-4, gpt-4.1)
# COPILOT_MODEL=
